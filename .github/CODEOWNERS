/gunicorn_config.py            @luniemma

# CI / supply chain — security-relevant changes.
/.github/workflows/            @luniemma
/.github/dependabot.yml        @luniemma
/.github/CODEOWNERS            @luniemma

# Security policy — never merge without an owner review.
/SECURITY.md                   @luniemma
